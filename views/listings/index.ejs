<% layout("layouts/boilerplate") %>

<style>
  #filters {
    display: flex;
    flex-wrap: wrap;
    gap: 2rem;
    margin-bottom: 2rem;
    align-items: center;
  }

  .filter {
    text-align: center;
    opacity: 0.7;
    text-decoration: none;
    color: black;
  }

  .filter:hover {
    opacity: 1;
    cursor: pointer;
  }

  .filter p {
    font-size: 0.8rem;
    margin: 0;
  }

  .tax-info {
    display: none;
  }

  .tax-toggle {
    border: 1px solid black;
    border-radius: 1rem;
    height: 3.2rem;
    padding: 1rem;
    margin-left: 2rem;
    display: flex;
    align-items: center;
  }
</style>

<div id="filters">

  <!-- ALL -->
  <a href="/listings" class="filter">
    <div><i class="fa-solid fa-border-all"></i></div>
    <p>All</p>
  </a>

  <!-- TRENDING -->
  <a href="/listings?category=Trending" class="filter">
    <div><i class="fa-solid fa-fire"></i></div>
    <p>Trending</p>
  </a>

  <!-- ROOMS -->
  <a href="/listings?category=Rooms" class="filter">
    <div><i class="fa-solid fa-bed"></i></div>
    <p>Rooms</p>
  </a>

  <!-- ICONIC CITIES -->
  <a href="/listings?category=Iconic Cities" class="filter">
    <div><i class="fa-solid fa-mountain-city"></i></div>
    <p>Iconic Cities</p>
  </a>

  <!-- MOUNTAINS -->
  <a href="/listings?category=Mountains" class="filter">
    <div><i class="fa-solid fa-mountain"></i></div>
    <p>Mountains</p>
  </a>

  <!-- CASTLES -->
  <a href="/listings?category=Castles" class="filter">
    <div><i class="fa-brands fa-fort-awesome"></i></div>
    <p>Castles</p>
  </a>

  <!-- AMAZING POOLS -->
  <a href="/listings?category=Amazing Pools" class="filter">
    <div><i class="fa-solid fa-person-swimming"></i></div>
    <p>Amazing Pools</p>
  </a>

  <!-- CAMPING -->
  <a href="/listings?category=Camping" class="filter">
    <div><i class="fa-solid fa-campground"></i></div>
    <p>Camping</p>
  </a>

  <!-- FARMS -->
  <a href="/listings?category=Farms" class="filter">
    <div><i class="fa-solid fa-cow"></i></div>
    <p>Farms</p>
  </a>

  <!-- ARCTIC -->
  <a href="/listings?category=Arctic" class="filter">
    <div><i class="fa-regular fa-snowflake"></i></div>
    <p>Arctic</p>
  </a>

   <!-- DOME -->
  <a href="/listings?category=Farms" class="filter">
    <div><i class="fa-solid fa-landmark-dome"></i></div>
    <p>Domes</p>
  </a>

  <!-- BOATS -->
  <a href="/listings?category=Arctic" class="filter">
    <div><i class="fa-solid fa-sailboat"></i></div>
    <p>Boats</p>
  </a>

  <div class="tax-toggle">
    <div class="form-check-reverse form-switch">
      <input class="form-check-input" type="checkbox" role="switch" id="switchCheckDefault">
      <label class="form-check-label" for="switchCheckDefault">Display total after taxes</label>
    </div>
  </div>

</div>

<div class="row mt-3">
  <% for (let listing of allListings) { %>

    <div class="col-md-4 mb-4">
      <div class="card h-100 position-relative listing-card">

      <img 
        src="<%= listing.image?.url || 'https://images.unsplash.com/photo-1501785888041-af3ef285b470' %>"
        class="card-img-top"
        alt="listing image"
        style="height: 20rem; object-fit: cover;"
      />
          <div class="card-img-overlay"></div>
        <div class="card-body">
          <p class="card-text">
            <strong><%= listing.title %></strong><br/>

            <% if (listing.price) { %>
              ₹ <%= listing.price.toLocaleString("en-IN") %> / night
            <% } %>
            <i class="tax-info"> &nbsp; &nbsp; +18% GST</i>
          </p>

          <!-- Invisible link that makes whole card clickable -->
          <a href="/listings/<%= listing._id %>" class="stretched-link"></a>
        </div>

      </div>
    </div>

  <% } %>
</div>

<script>
  let taxSwitch = document.getElementById("switchCheckDefault");
  taxSwitch.addEventListener("click", () => {
    let taxInfo = document.getElementsByClassName("tax-info");
    for(info of taxInfo) {
      if(info.style.display != "inline") {
        info.style.display = "inline";
      } else {
        info.style.display = "none";
      }
    }
  });
</script>